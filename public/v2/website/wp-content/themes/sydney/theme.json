{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "740px",
			"wideSize": "1140px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "30px",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(30px, 5vw, 60px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(30px, 7vw, 80px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(50px, 7vw, 100px)",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "clamp(50px, 10vw, 120px)",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Natural",
					"slug": "natural",
					"shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Lifted",
					"slug": "lifted",
					"shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Deep",
					"slug": "deep",
					"shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Sharp",
					"slug": "sharp",
					"shadow": "6px 6px 0px rgba(0, 0, 0, 0.2)"
				},
				{
					"name": "Outlined",
					"slug": "outlined",
					"shadow": "6px 6px 0px -3px rgb(255, 255, 255), 6px 6px rgb(0, 0, 0)"
				},
				{
					"name": "Crisp",
					"slug": "crisp",
					"shadow": "6px 6px 0px rgb(0, 0, 0)"
        }
      ]
    },
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "14px"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "16px"
				},
				{
					"name": "Regular",
					"slug": "regular",
					"size": "18px",
					"fluid": {
						"min": "16px",
						"max": "18px"
					}
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "24px",
					"fluid": {
						"min": "16px",
						"max": "24px"
					}
				},
				{
					"name": "X-Large",
					"slug": "x-large",
					"size": "32px",
					"fluid": {
						"min": "20px",
						"max": "32px"
					}
				},
				{
					"name": "XX-Large",
					"slug": "xx-large",
					"size": "48px",
					"fluid": {
						"min": "32px",
						"max": "48px"
					}
				}
			]
		}
	},
    "templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "uncategorized"
		},
		{
			"name": "single",
			"title": "Single",
			"area": "uncategorized"
		},
        {
            "name": "footer",
            "title": "Footer",
            "area": "uncategorized"
        },
		{
			"name": "archive",
			"title": "Archive",
			"area": "uncategorized"
		},
		{
			"name": "search",
			"title": "Search",
			"area": "uncategorized"
		},
		{
			"name": "404",
			"title": "404",
			"area": "uncategorized"
		},
		{
			"name": "page",
			"title": "Page",
			"area": "uncategorized"
		}
    ]
}